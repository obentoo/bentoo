Fix static_assert(sizeof(Slot) == 32) on 32-bit platforms. On 32-bit x86,
uint64_t has 4-byte alignment making Slot 28 bytes instead of 32.
Add alignas(8) to force 8-byte alignment so the struct size is 32 on all
platforms.

--- a/layers/state_tracker/descriptor_hashing.h
+++ b/layers/state_tracker/descriptor_hashing.h
@@ -82,7 +82,7 @@ struct DescriptorHashTable {
     };
 
     // Represents single "slot" in our linear buffer allocation
-    struct Slot {
+    struct alignas(8) Slot {
         uint64_t key;
         Entry entry;
     };
