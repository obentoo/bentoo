Link against system harfbuzz-raster (HarfBuzz >= 14.x)

TextServerAdvanced uses the hb_raster_* API, which upstream HarfBuzz 14.x ships
in a separate library (libharfbuzz-raster.so / pkg-config harfbuzz-raster).
detect.py only links harfbuzz + harfbuzz-icu when builtin_harfbuzz=no, causing
undefined references to hb_raster_image_get_buffer / hb_raster_paint_destroy /
hb_raster_draw_destroy. Add harfbuzz-raster to the pkg-config call.

--- a/platform/linuxbsd/detect.py
+++ b/platform/linuxbsd/detect.py
@@ -256,7 +256,7 @@
         env.ParseConfig("pkg-config icu-i18n icu-uc --cflags --libs")
 
     if not env["builtin_harfbuzz"]:
-        env.ParseConfig("pkg-config harfbuzz harfbuzz-icu --cflags --libs")
+        env.ParseConfig("pkg-config harfbuzz harfbuzz-icu harfbuzz-raster --cflags --libs")
 
     if not env["builtin_icu4c"] or not env["builtin_harfbuzz"]:
         print_warning(
