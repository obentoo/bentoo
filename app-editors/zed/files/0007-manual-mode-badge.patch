+    // ---- R4.1/R4.2: badge visibility is keyed to the mode id `default`, nothing else ----
+
+    #[test]
+    fn manual_badge_shown_only_for_default_mode_id() {
+        assert!(shows_manual_mode_badge(
+            acp::SessionModeId::new("default").0.as_ref()
+        ));
+
+        for other in ["acceptEdits", "bypassPermissions", "plan", "manual", ""] {
+            assert!(
+                !shows_manual_mode_badge(acp::SessionModeId::new(other).0.as_ref()),
+                "badge must be keyed to the id `default`, not shown for `{other}`"
+            );
+        }
+    }
+
+    // ---- R4.2: badge visibility clears when the session mode changes ----
+
+    #[gpui::test]
+    fn manual_badge_state_clears_when_mode_changes(cx: &mut TestAppContext) {
+        let agent_server = Rc::new(TestAgentServer::default());
+        let session_modes = Rc::new(BadgeTestSessionModes::new());
+        let fs: Arc<dyn Fs> = FakeFs::new(cx.executor());
+
+        cx.update(|cx| {
+            let session_modes: Rc<dyn AgentSessionModes> = session_modes.clone();
+            let agent_server: Rc<dyn AgentServer> = agent_server.clone();
+            let selector = cx.new(|_| ModeSelector::new(session_modes, agent_server, fs));
+
+            selector.update(cx, |selector, cx| {
+                assert!(
+                    shows_manual_mode_badge(selector.mode().0.as_ref()),
+                    "session starts in `default` (Manual): badge visible"
+                );
+
+                selector.set_mode(acp::SessionModeId::new("acceptEdits"), cx);
+                assert!(
+                    !shows_manual_mode_badge(selector.mode().0.as_ref()),
+                    "leaving `default` removes the badge"
+                );
+
+                selector.set_mode(acp::SessionModeId::new("default"), cx);
+                assert!(
+                    shows_manual_mode_badge(selector.mode().0.as_ref()),
+                    "returning to `default` restores the badge"
+                );
+            });
+        });
+    }
+
+    /// Session-modes double whose mode set mirrors the Claude adapter's permission
+    /// modes and starts in `default` (Manual).
+    struct BadgeTestSessionModes {
+        current_mode: RefCell<acp::SessionModeId>,
+    }
+
+    impl BadgeTestSessionModes {
+        fn new() -> Self {
+            Self {
+                current_mode: RefCell::new(acp::SessionModeId::new("default")),
+            }
+        }
+    }
+
+    impl AgentSessionModes for BadgeTestSessionModes {
+        fn current_mode(&self) -> acp::SessionModeId {
+            self.current_mode.borrow().clone()
+        }
+
+        fn all_modes(&self) -> Vec<acp::SessionMode> {
+            vec![
+                acp::SessionMode::new("default", "Manual"),
+                acp::SessionMode::new("acceptEdits", "Accept Edits"),
+            ]
+        }
+
+        fn set_mode(&self, mode: acp::SessionModeId, _cx: &mut App) -> Task<anyhow::Result<()>> {
+            *self.current_mode.borrow_mut() = mode;
+            Task::ready(Ok(()))
+        }
+    }
 }
