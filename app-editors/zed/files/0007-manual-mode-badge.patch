+/// Whether the Manual-mode badge is shown next to a config-option selector.
+///
+/// Agents that surface their permission mode as a Mode-category select config
+/// option (rather than session modes) get the same badge as the dedicated
+/// mode selector: shown while the current value id is `default`, cleared on
+/// any other value.
+fn shows_manual_mode_badge_for_option(option: &acp::SessionConfigOption) -> bool {
+    option.category == Some(acp::SessionConfigOptionCategory::Mode)
+        && match &option.kind {
+            acp::SessionConfigKind::Select(select) => {
+                crate::mode_selector::shows_manual_mode_badge(select.current_value.0.as_ref())
+            }
+            _ => false,
+        }
+}
+
 fn setting_value_for_config_option_value(
     value: &acp::SessionConfigOptionValue,
 ) -> Option<AgentConfigOptionValue> {
@@ -1275,6 +1317,57 @@ mod tests {
         assert!(!handled);
     }
 
+    // ---- R4.1/R4.2: manual-mode badge next to the Mode-category select trigger ----
+
+    #[test]
+    fn manual_badge_shown_only_for_mode_category_select_with_default_value() {
+        let mode_option = |current_value: &'static str| {
+            acp::SessionConfigOption::select(
+                "permission-mode",
+                "Permission Mode",
+                current_value,
+                vec![
+                    acp::SessionConfigSelectOption::new("default", "Manual"),
+                    acp::SessionConfigSelectOption::new("auto", "Auto"),
+                    acp::SessionConfigSelectOption::new("acceptEdits", "Accept Edits"),
+                ],
+            )
+            .category(acp::SessionConfigOptionCategory::Mode)
+        };
+
+        assert!(
+            shows_manual_mode_badge_for_option(&mode_option("default")),
+            "Mode-category select with current value id `default` shows the badge"
+        );
+
+        for other in ["auto", "acceptEdits"] {
+            assert!(
+                !shows_manual_mode_badge_for_option(&mode_option(other)),
+                "badge is keyed to the value id `default`, not shown for `{other}`"
+            );
+        }
+
+        let non_mode_category = acp::SessionConfigOption::select(
+            "model",
+            "Model",
+            "default",
+            vec![acp::SessionConfigSelectOption::new("default", "Default")],
+        )
+        .category(acp::SessionConfigOptionCategory::Model);
+        assert!(
+            !shows_manual_mode_badge_for_option(&non_mode_category),
+            "badge only applies to the Mode category, even for a `default` value id"
+        );
+
+        let boolean_mode_option =
+            acp::SessionConfigOption::boolean("permission-mode", "Permission Mode", false)
+                .category(acp::SessionConfigOptionCategory::Mode);
+        assert!(
+            !shows_manual_mode_badge_for_option(&boolean_mode_option),
+            "badge only applies to select options"
+        );
+    }
+
