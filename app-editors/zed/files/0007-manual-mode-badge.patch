+/// Whether the Manual-mode badge is shown for the given mode id.
+///
+/// The Claude adapter's `default` permission mode is surfaced to users as
+/// "Manual": the agent waits for approval before acting. The badge is keyed
+/// strictly to the mode id (never the display name), so it shows for
+/// `default` only and disappears on any other mode.
+///
+/// Shared between [`ModeSelector`] (session-modes agents) and the
+/// config-options selector (`crate::config_options`), which renders the same
+/// badge next to Mode-category select options.
+pub(crate) fn shows_manual_mode_badge(mode_id: &str) -> bool {
+    mode_id == "default"
+}
+
 impl Render for ModeSelector {
     fn render(&mut self, _window: &mut Window, cx: &mut Context<Self>) -> impl IntoElement {
         let current_mode_id = self.connection.current_mode();
@@ -154,7 +168,7 @@ impl Render for ModeSelector {
             .end_icon(Icon::new(icon).size(IconSize::XSmall).color(Color::Muted))
             .disabled(self.setting_mode);
 
-        PopoverMenu::new("mode-selector")
+        let selector_menu = PopoverMenu::new("mode-selector")
             .trigger_with_tooltip(
                 trigger_button,
                 Tooltip::element({
@@ -191,7 +205,34 @@ impl Render for ModeSelector {
             .menu(move |window, cx| {
                 this.update(cx, |this, cx| this.build_context_menu(window, cx))
                     .ok()
-            })
+            });
+
+        h_flex()
+            .gap_1()
+            .when(
+                shows_manual_mode_badge(current_mode_id.0.as_ref()),
+                |this| {
+                    this.child(
+                        h_flex()
+                            .id("manual-mode-badge")
+                            .gap_0p5()
+                            .child(
+                                Icon::new(IconName::DebugPause)
+                                    .size(IconSize::XSmall)
+                                    .color(Color::Muted),
+                            )
+                            .child(
+                                Label::new("Waits for approval")
+                                    .size(LabelSize::Small)
+                                    .color(Color::Muted),
+                            )
+                            .tooltip(Tooltip::text(
+                                "Manual mode: the agent asks for approval before making changes",
+                            )),
+                    )
+                },
+            )
+            .child(selector_menu)
     }
 }
 
