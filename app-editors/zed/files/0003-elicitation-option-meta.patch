+
+    #[test]
+    fn single_select_uses_value_as_label_when_description_present() {
+        let schema = acp::StringPropertySchema::new().one_of(vec![titled_option_with_meta(
+            "production",
+            "Production — the live environment",
+            serde_json::json!({ "description": "The live environment", "preview": "prod" }),
+        )]);
+        let options = single_select_options(&schema);
+        assert_eq!(options.len(), 1);
+        assert_eq!(options[0].value, "production");
+        assert_eq!(options[0].label.as_ref(), "production");
+        assert_eq!(
+            options[0].description.as_deref(),
+            Some("The live environment")
+        );
+        assert_eq!(options[0].preview.as_deref(), Some("prod"));
+    }
+
+    #[test]
+    fn single_select_uses_title_as_label_without_description() {
+        let schema = acp::StringPropertySchema::new()
+            .one_of(vec![acp::EnumOption::new("production", "Production")]);
+        let options = single_select_options(&schema);
+        assert_eq!(options[0].label.as_ref(), "Production");
