+        )]);
+        let options = multi_select_options(&schema);
+        assert_eq!(options[0].value, "repository");
+        assert_eq!(options[0].label.as_ref(), "repository");
+        assert_eq!(options[0].description.as_deref(), Some("Repo access"));
+        assert_eq!(options[0].preview.as_deref(), Some("```\ndiff\n```"));
+    }
+
+    #[test]
+    fn multi_select_untitled_options_carry_no_detail() {
+        let schema = acp::MultiSelectPropertySchema::new(vec![
+            "alpha".to_string(),
+            "beta".to_string(),
+        ]);
+        let options = multi_select_options(&schema);
+        assert_eq!(options[0].label.as_ref(), "alpha");
+        assert!(
+            options
+                .iter()
+                .all(|option| option.description.is_none() && option.preview.is_none())
+        );
+    }
 }
 
