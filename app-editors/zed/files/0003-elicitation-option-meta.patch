+        let detail = ask_user_question_option_detail(Some(&meta));
+        assert!(detail.description.is_none() && detail.preview.is_none());
+    }
+
+    #[test]
+    fn option_detail_ignores_wrong_field_types() {
+        let meta = option_meta_entry(serde_json::json!({
+            "description": 42,
+            "preview": ["not", "a", "string"],
+        }));
+        let detail = ask_user_question_option_detail(Some(&meta));
+        assert!(detail.description.is_none() && detail.preview.is_none());
+    }
+
+    #[test]
+    fn option_detail_tolerates_unknown_extra_fields() {
+        let meta = option_meta_entry(serde_json::json!({
+            "description": "kept",
+            "preview": "kept too",
+            "futureField": { "nested": true },
+        }));
+        let detail = ask_user_question_option_detail(Some(&meta));
+        assert_eq!(detail.description.as_deref(), Some("kept"));
