+    #[test]
+    fn option_detail_parses_description_and_preview() {
+        let meta = option_meta_entry(serde_json::json!({
+            "description": "The live environment",
+            "preview": "```rust\nfn main() {}\n```",
+        }));
+        let detail = ask_user_question_option_detail(Some(&meta));
+        assert_eq!(detail.description.as_deref(), Some("The live environment"));
+        assert_eq!(detail.preview.as_deref(), Some("```rust\nfn main() {}\n```"));
+    }
+
+    #[test]
+    fn option_detail_parses_description_only() {
+        let meta = option_meta_entry(serde_json::json!({ "description": "Just a note" }));
+        let detail = ask_user_question_option_detail(Some(&meta));
+        assert_eq!(detail.description.as_deref(), Some("Just a note"));
+        assert!(detail.preview.is_none());
+    }
+
+    #[test]
+    fn option_detail_parses_preview_only() {
+        let meta = option_meta_entry(serde_json::json!({ "preview": "# Heading" }));
+        let detail = ask_user_question_option_detail(Some(&meta));
+        assert!(detail.description.is_none());
+        assert_eq!(detail.preview.as_deref(), Some("# Heading"));
+    }
+
