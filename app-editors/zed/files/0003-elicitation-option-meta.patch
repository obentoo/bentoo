+/// Key under which the Claude Code adapter attaches per-option description and
+/// preview metadata to an elicitation enum option's `_meta` (adapter >= v0.46.0).
+const ASK_USER_QUESTION_OPTION_META_KEY: &str = "_claude/askUserQuestionOption";
+
+/// Parsed per-option detail extracted from an enum option's `_meta`.
+struct OptionDetail {
+    description: Option<SharedString>,
+    preview: Option<String>,
+}
+
+/// Extract `{description?, preview?}` from an enum option's `_meta` under
+/// [`ASK_USER_QUESTION_OPTION_META_KEY`], tolerantly. An absent key, a non-object
+/// entry, or wrong-typed fields all yield `None` — never an error (R1.2) — and
+/// unknown extra fields are ignored (R1.3).
+fn ask_user_question_option_detail(meta: Option<&acp::Meta>) -> OptionDetail {
+    let entry = meta
+        .and_then(|meta| meta.get(ASK_USER_QUESTION_OPTION_META_KEY))
+        .and_then(|value| value.as_object());
+    let Some(entry) = entry else {
+        return OptionDetail {
+            description: None,
+            preview: None,
+        };
+    };
+    OptionDetail {
+        description: entry
+            .get("description")
+            .and_then(|value| value.as_str())
+            .map(|description| SharedString::from(description.to_string())),
+        preview: entry
+            .get("preview")
+            .and_then(|value| value.as_str())
+            .map(|preview| preview.to_string()),
+    }
+}
+
+/// Build a titled option, applying the parsed `_meta` detail and the R2.2 label
+/// rule: when a description is present the option's `value` becomes the primary
+/// label (the adapter flattens "label — description" into `title` only when a
+/// description exists), otherwise the human-readable `title` is used.
+fn titled_option(value: &str, title: &str, meta: Option<&acp::Meta>) -> ElicitationOption {
+    let detail = ask_user_question_option_detail(meta);
+    let label = if detail.description.is_some() {
+        SharedString::from(value.to_string())
+    } else {
+        SharedString::from(title.to_string())
+    };
+    ElicitationOption {
+        value: value.to_string(),
+        label,
+        description: detail.description,
+        preview: detail.preview,
+    }
+}
+
+/// Build a plain option with no `_meta` detail (enum-values and untitled arms).
+fn plain_option(value: &str) -> ElicitationOption {
+    ElicitationOption {
+        value: value.to_string(),
+        label: SharedString::from(value.to_string()),
+        description: None,
+        preview: None,
+    }
+}
+
 fn single_select_options(schema: &acp::StringPropertySchema) -> Vec<ElicitationOption> {
     if let Some(options) = &schema.one_of {
         return options
             .iter()
-            .map(|option| ElicitationOption {
-                value: option.value.clone(),
-                label: SharedString::from(option.title.clone()),
-            })
+            .map(|option| titled_option(&option.value, &option.title, option.meta.as_ref()))
             .collect();
     }
 
