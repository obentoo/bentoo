<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE pkgmetadata SYSTEM "https://www.gentoo.org/dtd/metadata.dtd">
<pkgmetadata>
	<maintainer type="person">
		<email>lucascs@proton.me</email>
		<name>Lucas C.S.</name>
	</maintainer>
	<longdescription lang="en">
		Zed is a high-performance, multiplayer code editor from the creators
		of Atom and Tree-sitter. This is the source-compiled package.
		For the pre-built binary version, use app-editors/zed-bin instead.
	</longdescription>
	<use>
		<flag name="wayland">Enable Wayland display server support</flag>
		<flag name="X">Enable X11 display server support</flag>
	</use>
	<upstream>
		<remote-id type="github">zed-industries/zed</remote-id>
		<bugs-to>https://github.com/zed-industries/zed/issues</bugs-to>
		<doc lang="en">https://zed.dev/docs</doc>
		<changelog>https://github.com/zed-industries/zed/releases/tag/v0.228.0-pre</changelog>
	</upstream>
</pkgmetadata>
