Upstream regression: pi_blending_mode/ppsz_blending_mode are placed inside
the HAVE_FRIBIDI guard but are referenced unconditionally in vlc_module_begin(),
breaking the build when FriBidi is disabled.

Move the arrays out of the #ifdef HAVE_FRIBIDI block.

Introduced by commit 95fb4927885bd29d431017ea69b6d43a63e1c360
("freetype: add transparent (knockout) blending mode.")

--- a/modules/text_renderer/freetype/freetype.c
+++ b/modules/text_renderer/freetype/freetype.c
@@ -122,6 +122,7 @@
 static const char *const ppsz_text_direction[] = {
     N_("Left to right"), N_("Right to left"), N_("Auto"),
 };
+#endif

 static const int pi_blending_mode[] = {
     0, 1
@@ -130,8 +131,6 @@
     N_("Overlay"), N_("Transparent"),
 };

-#endif
-
 vlc_module_begin ()
