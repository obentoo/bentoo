Fix missing cstdint include in tgcalls headers

GCC 15 / recent libstdc++ no longer pulls <cstdint> through transitive
includes, breaking compilation of tgcalls headers that use uint8_t,
uint16_t, and uint64_t directly:

  Telegram/ThirdParty/tgcalls/tgcalls/DirectConnectionChannel.h:14:
    error: 'uint8_t' was not declared in this scope
  Telegram/ThirdParty/tgcalls/tgcalls/Instance.h:41:
    error: 'uint16_t' does not name a type
  Telegram/ThirdParty/tgcalls/tgcalls/Instance.h:157:
    error: 'uint64_t' does not name a type
  Telegram/ThirdParty/tgcalls/tgcalls/InstanceImpl.h:22:
    error: 'uint8_t' was not declared in this scope

--- tdesktop-6.8.1-full.orig/Telegram/ThirdParty/tgcalls/tgcalls/DirectConnectionChannel.h
+++ tdesktop-6.8.1-full/Telegram/ThirdParty/tgcalls/tgcalls/DirectConnectionChannel.h
@@ -4,6 +4,7 @@
 #include <functional>
 #include <memory>
 #include <vector>
+#include <cstdint>

 namespace tgcalls {

--- tdesktop-6.8.1-full.orig/Telegram/ThirdParty/tgcalls/tgcalls/Instance.h
+++ tdesktop-6.8.1-full/Telegram/ThirdParty/tgcalls/tgcalls/Instance.h
@@ -9,6 +9,7 @@

 #include "Stats.h"
 #include "DirectConnectionChannel.h"
+#include <cstdint>

 namespace rtc {
 template <typename VideoFrameT>
--- tdesktop-6.8.1-full.orig/Telegram/ThirdParty/tgcalls/tgcalls/InstanceImpl.h
+++ tdesktop-6.8.1-full/Telegram/ThirdParty/tgcalls/tgcalls/InstanceImpl.h
@@ -2,6 +2,7 @@
 #define TGCALLS_INSTANCE_IMPL_H

 #include "Instance.h"
+#include <cstdint>

 namespace tgcalls {
